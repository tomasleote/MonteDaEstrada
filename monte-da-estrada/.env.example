# Monte da Estrada - Environment Variables Configuration
# Copy this file to .env for local development

# ======================================
# Routing Configuration
# ======================================

# Base path for React Router
# Standalone deployment: /
# Parent site integration: /properties/monte-da-estrada
VITE_APP_BASE_PATH=/

# ======================================
# API Configuration
# ======================================

# Base URL for API requests (if using external API)
VITE_API_BASE_URL=https://api.montedaestrada.com

# ======================================
# CMS Configuration
# ======================================

# GitHub repository for Decap CMS
VITE_CMS_REPO=tomasleote/MonteDaEstrada

# Enable/disable admin panel access
# Set to false when integrated into parent site
VITE_ENABLE_ADMIN=true

# ======================================
# Feature Flags
# ======================================

# Enable analytics (Google Analytics, etc.)
VITE_ENABLE_ANALYTICS=false

# Enable booking system integration
VITE_ENABLE_BOOKING=true

# ======================================
# Development Configuration
# ======================================

# Port for development server (default: 5173)
# VITE_PORT=5173

# ======================================
# Production Notes
# ======================================

# For standalone production deployment:
# - Set VITE_APP_BASE_PATH=/
# - Set VITE_ENABLE_ADMIN=true

# For parent site integration:
# - Set VITE_APP_BASE_PATH=/properties/monte-da-estrada
# - Set VITE_ENABLE_ADMIN=false
# - Update VITE_API_BASE_URL to parent site API

# ======================================
# How to Use
# ======================================

# 1. Copy this file:
#    cp .env.example .env

# 2. Update values for your environment

# 3. Restart development server:
#    npm run dev

# 4. Build for production:
#    npm run build

# Note: Environment variables are embedded at build time
# Changes require rebuild to take effect in production
